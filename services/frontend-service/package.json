{
  "name": "k8sproject",
  "version": "1.0.0",
  "description": "Monorepo for Kubernetes microservices project",
  "private": true,
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "test:all": "npm run test:coverage --workspaces --if-present",
    "lint:all": "npm run lint --workspaces --if-present",
    "install:all": "npm install && npm run install --workspaces"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^17.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "connect-redis": "^7.1.1",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.17.3",
    "redis": "^4.6.13"
  }
}
